<!DOCTYPE html>
<html>
<head>
  <title>My Games</title>
  <link rel="stylesheet" href="styles.css">
</head>
<body>
  <h1>🎮 My Game Collection</h1>
  <div class="games-grid" id="games-list"></div>
  <script src="scripts.js"></script>
</body>
</html>
body { background: #111; color: white; font-family: sans-serif; }
h1 { text-align: center; padding: 20px; }
.games-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 15px;
  padding: 20px;
}
.game-card {
  background: #222; border-radius: 10px; padding: 15px; text-align: center;
}
.game-card img { width: 100%; height: 120px; object-fit: cover; border-radius: 8px; }
.play-btn {
  display: block; margin-top: 10px; padding: 8px;
  background: #007acc; color: white; text-decoration: none; border-radius: 5px;
}   
const games = [
  { title: "Snow Rider 3D", img: "https://via.placeholder.com/300?text=Snow+Rider", url: "games/snow-rider-3d.html" },
  { title: "Tetris", img: "https://via.placeholder.com/300?text=Tetris", url: "games/tetris.html" },
  { title: "Pac-Man", img: "https://via.placeholder.com/300?text=Pac-Man", url: "games/pacman.html" }
];

const container = document.getElementById("games-list");
games.forEach(game => {
  const div = document.createElement("div");
  div.className = "game-card";
  div.innerHTML = `
    <img src="${game.img}" alt="${game.title}">
    <h3>${game.title}</h3>
    <a href="${game.url}" class="play-btn" target="_blank">Play</a>
  `;
  container.appendChild(div);
});   
